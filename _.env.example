# Copy this file to .env on the VPS and replace every placeholder before running Docker Compose.

# GHCR image source. Keep owner and repository lowercase because container image names are lowercase.
GHCR_OWNER=your-github-owner
GHCR_REPOSITORY=telegram-ia
IMAGE_TAG=latest

# PostgreSQL container settings.
POSTGRES_DB=telegram_ia
POSTGRES_USER=telegram_ia
POSTGRES_PASSWORD=change-me-db-password

# Spring Boot runtime profile.
SPRING_PROFILES_ACTIVE=prod

# Application datasource. The host must match the postgres service name from docker-compose.example.yml.
TELEGRAM_IA_DATASOURCE_URL=jdbc:postgresql://postgres:5432/telegram_ia
TELEGRAM_IA_DATASOURCE_USERNAME=telegram_ia
TELEGRAM_IA_DATASOURCE_PASSWORD=change-me-db-password

# Server-side token pepper. Use a long random secret and keep it stable while pending invitations exist.
TELEGRAM_LINK_TOKEN_PEPPER=change-me-to-a-long-random-secret

# Optional bot username used when generating Telegram deep links.
TELEGRAM_LINK_BOT_USERNAME=your_bot_username

# MVP simulated current user. Replace with values that exist in your production seed data.
TELEGRAM_LINK_CURRENT_USER_COMPANY_USER_ID=00000000-0000-0000-0000-000000000000
TELEGRAM_LINK_CURRENT_USER_COMPANY_ID=00000000-0000-0000-0000-000000000000
TELEGRAM_LINK_CURRENT_USER_ROLE=ADMIN
TELEGRAM_LINK_CURRENT_USER_STATUS=ACTIVE
